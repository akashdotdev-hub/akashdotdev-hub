#!/bin/bash

if [ "$#" -ne 1 ]; then
    echo "Usage: log-archive <log-directory>"
    exit 1
fi

LOG_DIR=$1

if [ ! -d "$LOG_DIR" ]; then
    echo "Error: Directory $LOG_DIR does not exist."
    exit 1
fi

# Create a new directory for archives if it doesn't exist
ARCHIVE_DIR="archive"
mkdir -p "$ARCHIVE_DIR"

# Get current date and time
DATETIME=$(date +"%Y%m%d_%H%M%S")
ARCHIVE_FILE="logs_archive_${DATETIME}.tar.gz"
ARCHIVE_PATH="${ARCHIVE_DIR}/${ARCHIVE_FILE}"

# Compress the log directory
tar -czf "$ARCHIVE_PATH" -C "$(dirname "$LOG_DIR")" "$(basename "$LOG_DIR")"

if [ $? -eq 0 ]; then
    # Log the archive info
    LOG_FILE="archive_log.txt"
    echo "Archived $LOG_DIR at $(date +"%Y-%m-%d %H:%M:%S") into $ARCHIVE_PATH" >> "$LOG_FILE"
    echo "Successfully archived logs to $ARCHIVE_PATH"
else
    echo "Failed to archive logs."
    exit 1
fi
